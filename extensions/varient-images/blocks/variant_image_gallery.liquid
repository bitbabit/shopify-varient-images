{% comment %}
  Self-contained variant gallery: no theme CSS selectors required.
  Add the block on the product template and assign images in the app.
{% endcomment %}

{% assign first_variant = product.selected_or_first_available_variant %}

<style>
  .variant-img-app-block {
    width: 100%;
    max-width: 100%;
    margin-bottom: 1rem;
  }
  .variant-img-gallery {
    width: 100%;
    max-width: 100%;
  }
  .variant-img-gallery__main {
    width: 100%;
    background: rgb(var(--color-background, 255 255 255));
    border-radius: 8px;
    overflow: hidden;
  }
  .variant-img-gallery__hero {
    width: 100%;
    max-width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
    vertical-align: middle;
  }
  .variant-img-gallery__thumbs {
    display: flex;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 8px;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 12px 4px 16px;
    margin: 0;
    list-style: none;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scroll-snap-type: x mandatory;
  }
  .variant-img-gallery__thumb {
    flex: 0 0 auto;
    scroll-snap-align: start;
    padding: 0;
    margin: 0;
    border: 2px solid transparent;
    border-radius: 8px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.06);
    cursor: pointer;
    line-height: 0;
    transition: border-color 0.15s ease;
  }
  .variant-img-gallery__thumb[aria-current="true"] {
    border-color: currentColor;
  }
  .variant-img-gallery__thumb img {
    width: 72px;
    height: 72px;
    object-fit: cover;
    display: block;
    pointer-events: none;
  }
  .variant-img-gallery--empty {
    padding: 12px;
    font-size: 0.9rem;
    color: rgba(var(--color-foreground, 18 18 18), 0.65);
    border: 1px dashed rgba(var(--color-foreground, 18 18 18), 0.2);
    border-radius: 8px;
    text-align: center;
  }
</style>

<div class="variant-img-app-block" data-variant-img-block="{{ block.id }}">
  <div id="variant-img-root-{{ block.id }}">
    {% assign vimgs = first_variant.metafields.custom.variant_images.value %}
    {% if vimgs and vimgs.size > 0 %}
      <div class="variant-img-gallery" data-variant-img-gallery>
        <div class="variant-img-gallery__main">
          {% assign first_img = vimgs | first %}
          <img
            class="variant-img-gallery__hero"
            src="{{ first_img | image_url: width: 1400 }}"
            alt="{{ first_img.alt | default: product.title | escape }}"
            width="1400"
            loading="eager"
            sizes="(min-width: 990px) 60vw, 100vw"
          >
        </div>
        <div class="variant-img-gallery__thumbs" role="list">
          {% for image in vimgs %}
            <button
              type="button"
              class="variant-img-gallery__thumb"
              role="listitem"
              data-full-src="{{ image | image_url: width: 1400 }}"
              data-full-alt="{{ image.alt | default: product.title | escape }}"
              aria-label="{{ image.alt | default: product.title | escape }}"
              aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              <img
                src="{{ image | image_url: width: 200 }}"
                alt=""
                width="72"
                height="72"
                loading="{% if forloop.index <= 6 %}eager{% else %}lazy{% endif %}"
              >
            </button>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="variant-img-gallery--empty" data-variant-empty>
        {{ block.settings.empty_message }}
      </div>
    {% endif %}
  </div>
</div>

<script>
  window.variantImages = window.variantImages || {};
  window.variantImages["{{ block.id }}"] = {
    rootId: "variant-img-root-{{ block.id }}",
    byVariantId: {
      {%- for variant in product.variants -%}
        "{{ variant.id }}": [
          {%- assign vimgs = variant.metafields.custom.variant_images.value -%}
          {%- if vimgs -%}
            {%- for image in vimgs -%}
              {
                "src": {{ image | image_url: width: 1400 | json }},
                "thumb": {{ image | image_url: width: 200 | json }},
                "alt": {{ image.alt | default: product.title | json }}
              }{%- unless forloop.last -%},{%- endunless -%}
            {%- endfor -%}
          {%- endif -%}
        ]{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    },
    emptyMessage: {{ block.settings.empty_message | json }}
  };

  (function () {
    var cfg = window.variantImages["{{ block.id }}"];
    if (!cfg) return;

    function escAttr(s) {
      return String(s == null ? "" : s)
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/</g, "&lt;");
    }

    function buildGalleryHtml(images) {
      if (!images || !images.length) return "";
      var first = images[0];
      var mainSrc = escAttr(first.src);
      var mainAlt = escAttr(first.alt);
      var parts = [];
      parts.push('<div class="variant-img-gallery" data-variant-img-gallery>');
      parts.push('<div class="variant-img-gallery__main">');
      parts.push(
        '<img class="variant-img-gallery__hero" src="' +
          mainSrc +
          '" alt="' +
          mainAlt +
          '" width="1400" loading="eager" sizes="(min-width: 990px) 60vw, 100vw" />'
      );
      parts.push("</div>");
      parts.push('<div class="variant-img-gallery__thumbs" role="list">');
      for (var i = 0; i < images.length; i++) {
        var img = images[i];
        var thumbSrc = escAttr(img.thumb || img.src);
        var fullSrc = escAttr(img.src);
        var alt = escAttr(img.alt);
        var current = i === 0 ? "true" : "false";
        parts.push(
          '<button type="button" class="variant-img-gallery__thumb" role="listitem" data-full-src="' +
            fullSrc +
            '" data-full-alt="' +
            alt +
            '" aria-label="' +
            alt +
            '" aria-current="' +
            current +
            '">'
        );
        parts.push(
          '<img src="' +
            thumbSrc +
            '" alt="" width="72" height="72" loading="' +
            (i < 6 ? "eager" : "lazy") +
            '" />'
        );
        parts.push("</button>");
      }
      parts.push("</div></div>");
      return parts.join("");
    }

    function bindThumbStrip(root) {
      var gallery = root.querySelector("[data-variant-img-gallery]");
      if (!gallery || gallery._variantImgThumbBound) return;
      gallery._variantImgThumbBound = true;
      gallery.addEventListener("click", function (ev) {
        var btn = ev.target.closest(".variant-img-gallery__thumb");
        if (!btn || !gallery.contains(btn)) return;
        var hero = gallery.querySelector(".variant-img-gallery__hero");
        if (!hero) return;
        var full = btn.getAttribute("data-full-src");
        var fullAlt = btn.getAttribute("data-full-alt");
        if (full) hero.setAttribute("src", full);
        if (fullAlt != null) hero.setAttribute("alt", fullAlt);
        gallery.querySelectorAll(".variant-img-gallery__thumb").forEach(function (t) {
          t.setAttribute("aria-current", t === btn ? "true" : "false");
        });
      });
    }

    function getVariantIdFromEvent(ev) {
      if (!ev || !ev.detail) return null;
      var d = ev.detail;
      if (d.variant && d.variant.id != null) return String(d.variant.id);
      if (d.variantId != null) return String(d.variantId);
      return null;
    }

    function parseVariantFromUrl() {
      var m = /(?:\?|&)variant=(\d+)/.exec(window.location.search);
      return m ? m[1] : null;
    }

    function applyVariant(variantIdStr) {
      var root = document.getElementById(cfg.rootId);
      if (!root) return;
      var list = cfg.byVariantId[variantIdStr];
      if (list && list.length) {
        root.innerHTML = buildGalleryHtml(list);
        bindThumbStrip(root);
      } else {
        root.innerHTML =
          '<div class="variant-img-gallery--empty" data-variant-empty>' +
          escAttr(cfg.emptyMessage) +
          "</div>";
      }
    }

    function onVariantChange(ev) {
      var id = getVariantIdFromEvent(ev);
      if (id) applyVariant(id);
    }

    function onSelectChange(ev) {
      var t = ev.target;
      if (!t) return;
      if (t.name === "id" || t.getAttribute("name") === "id") {
        applyVariant(String(t.value));
      }
    }

    document.addEventListener("variant:changed", onVariantChange);
    document.addEventListener("change", onSelectChange);

    function boot() {
      var root = document.getElementById(cfg.rootId);
      if (!root) return;
      bindThumbStrip(root);
      var urlVariant = parseVariantFromUrl();
      if (urlVariant != null && cfg.byVariantId[urlVariant] !== undefined) {
        applyVariant(String(urlVariant));
      }
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", boot);
    } else {
      boot();
    }

    document.addEventListener("shopify:section:load", function (ev) {
      var root = document.getElementById(cfg.rootId);
      if (ev && root && ev.target && ev.target.contains(root)) {
        boot();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Variant image gallery",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "paragraph",
      "content": "Shows custom variant images from metafield custom.variant_images. Add this block to the product template — no CSS selectors needed. Tip: use the theme editor to place it where the gallery should appear; you can hide the theme’s default product media if you only want these images."
    },
    {
      "type": "text",
      "id": "empty_message",
      "label": "Message when a variant has no custom images",
      "default": "No extra images for this variant. Assign images in the app."
    }
  ]
}
{% endschema %}
