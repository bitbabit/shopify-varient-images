# Copy to .env and fill in. Required for local dev and production.

# PostgreSQL — OAuth sessions only (variant images live in Shopify metafields).
# Local: docker compose up -d  OR  Neon / Render: https://neon.tech/docs/connect/connect-from-any-app
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/variantimg"

# From Shopify Partners → Apps → your app → API credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Public URL of this app (no trailing slash). Local: use CLI tunnel URL from `shopify app dev`
SHOPIFY_APP_URL=

# Must match shopify.app.toml access_scopes (comma-separated)
SCOPES=read_products,write_products,read_files,write_files

# Optional: use Shopify test billing on dev stores (see docs/BILLING_AND_PRIVACY.md)
# SHOPIFY_BILLING_TEST=true
